# Anthropic
ANTHROPIC_API_KEY=your_key_here

# Grant sources
SERPAPI_API_KEY=your_key_here
SERPER_API_KEY=your_key_here

# Email (Resend)
RESEND_API_KEY=your_key_here
SENDER_EMAIL=Infinite Money Glitch <noreply@gugul.xyz>

# Database — leave commented out for --mock --dry-run offline testing
# DATABASE_URL=postgresql://postgres:<password>@/infinitemoneyglitch?host=/cloudsql/<instance>

# Firebase Admin SDK
# Local: path to JSON file. Cloud Run: full JSON string (from Secret Manager).
FIREBASE_SERVICE_ACCOUNT=firebase-service-account.json

# CLI-only (used for --mock / --dry-run; server uses Firebase UID)
USER_ID=default
RECIPIENT_EMAIL=you@example.com
